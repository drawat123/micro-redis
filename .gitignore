# Build output (out-of-source; regenerated by cmake)
/build/

# Editor / OS cruft
.DS_Store
.idea/
.cache/
.vscode/
.devcontainer/
# NOTE: .vscode/ and .devcontainer/ ARE committed on purpose — they configure
# the shared dev environment (build/debug/IntelliSense). compile_commands.json
# lives under build/ (already ignored), so no need to ignore it separately.

# Object files / binaries, just in case
*.o
*.out
